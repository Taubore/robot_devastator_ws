{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ROS 2 - Build Devastator",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "source /opt/ros/jazzy/setup.bash && colcon build --symlink-install --packages-select commun interface_pico robot_devastator robot_devastator_bringup"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "ROS 2 - Build complet",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "source /opt/ros/jazzy/setup.bash && colcon build --symlink-install"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "ROS 2 - Nettoyer packages Devastator",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "./scripts/nettoyer_packages_ros.sh commun interface_pico robot_devastator robot_devastator_bringup"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "ROS 2 - Lancer interface Pico",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "source /opt/ros/jazzy/setup.bash && source install/setup.bash && ros2 launch robot_devastator_bringup interface_pico.launch.yaml"
            ],
            "problemMatcher": []
        },
        {
            "label": "ROS 2 - Lancer autonomie simple",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "source /opt/ros/jazzy/setup.bash && source install/setup.bash && ros2 launch robot_devastator_bringup autonomie_simple.launch.yaml"
            ],
            "problemMatcher": []
        }
    ]
}
