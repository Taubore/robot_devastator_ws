{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Principal",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "robot_devastator.principal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/lib/python3.12/site-packages:${env:PYTHONPATH}"
      }
    },
    {
      "name": "ServicePiper",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "robot_devastator.voix_piper_service",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/lib/python3.12/site-packages:${env:PYTHONPATH}"
      }
    },
    {
      "name": "InterfacePico",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "interface_pico.interface_pico",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/lib/python3.12/site-packages:${env:PYTHONPATH}"
      }
    }
  ],
  "compounds": [
    {
      "name": "Tous",
      "configurations": ["Principal", "ServicePiper", "InterfacePico"]
    },
    {
      "name": "Principal + Pico",
      "configurations": ["Principal", "InterfacePico"]
    }
  ]
}
