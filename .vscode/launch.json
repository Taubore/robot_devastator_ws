{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Nœud Python ROS 2",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "${input:modulePythonRos2}",
      "cwd": "${workspaceFolder}",
      "env": {
        // Le message généré par commun reste dans install après le build colcon.
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/lib/python3.12/site-packages:/opt/ros/jazzy/lib/python3.12/site-packages:${env:PYTHONPATH}",
        "LD_LIBRARY_PATH": "${workspaceFolder}/install/commun/lib:${env:LD_LIBRARY_PATH}"
      }
    }
  ],
  "inputs": [
    {
      "id": "modulePythonRos2",
      "type": "promptString",
      "description": "Module Python ROS 2 à déboguer",
      "default": "robot_devastator.evitement_obstacle"
    }
  ]
}
