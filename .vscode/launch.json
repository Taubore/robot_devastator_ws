{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Principal",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "robot_devastator.principal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/local/lib/python3.12/dist-packages:${workspaceFolder}/install/robot_devastator/lib/python3.12/site-packages:${workspaceFolder}/install/interface_pico/lib/python3.12/site-packages:/opt/ros/jazzy/lib/python3.12/site-packages:${env:PYTHONPATH}"
      }
    },
    {
      "name": "InterfacePico reel",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "interface_pico.interface_pico",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/local/lib/python3.12/dist-packages:${workspaceFolder}/install/robot_devastator/lib/python3.12/site-packages:${workspaceFolder}/install/interface_pico/lib/python3.12/site-packages:/opt/ros/jazzy/lib/python3.12/site-packages:${env:PYTHONPATH}"
      }
    },
    {
      "name": "InterfacePico simulation",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "interface_pico.interface_pico",
      "cwd": "${workspaceFolder}",
      "args": ["--ros-args", "-p", "mode_materiel:=simulation"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/robot_devastator:${workspaceFolder}/src/interface_pico:${workspaceFolder}/install/commun/local/lib/python3.12/dist-packages:${workspaceFolder}/install/robot_devastator/lib/python3.12/site-packages:${workspaceFolder}/install/interface_pico/lib/python3.12/site-packages:/opt/ros/jazzy/lib/python3.12/site-packages:${env:PYTHONPATH}"
      }
    }
  ],
  "compounds": [
    {
      "name": "Tous reel",
      "configurations": ["Principal", "InterfacePico reel"]
    },
    {
      "name": "Tous simulation",
      "configurations": ["Principal", "InterfacePico simulation"]
    }
  ]
}
